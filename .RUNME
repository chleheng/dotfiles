#!/usr/bin/env bash
set -Eeuo pipefail

repo_url="${DOTFILES_REPO:-https://github.com/chleheng/dotfiles.git}"
target="${DOTFILES_DIR:-$HOME/dotfiles}"

if [ ! -d "$target/.git" ]; then
  git clone "$repo_url" "$target"
else
  git -C "$target" pull --ff-only
fi

cd "$target"
exec ./scripts/bootstrap-ubuntu.sh "$@"
