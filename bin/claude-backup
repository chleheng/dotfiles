#!/usr/bin/env bash
# End-of-day backup: commit + push ~/.claude to chleheng/claude-backup
set -e

cd /home/q1/.claude

if git diff --quiet && git diff --cached --quiet && [ -z "$(git ls-files --others --exclude-standard)" ]; then
    echo "Nothing changed since last backup."
    exit 0
fi

DATE=$(date '+%Y-%m-%d %H:%M')
git add -A
git commit -m "Backup $DATE"
git push
echo "Backed up to github.com/chleheng/claude-backup"
