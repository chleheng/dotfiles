# dircolors tuned for very warm displays.
#
# Redshift/Gammastep at 1700K-1000K crushes blue/cyan contrast, so this
# palette avoids the default dark-blue directories and leans on brightness,
# underline, and warm high-contrast colors.

COLORTERM ?*
TERM *color*
TERM *direct*
TERM gnome
TERM screen*
TERM tmux*
TERM xterm*

RESET 0
NORMAL 00
FILE 00
DIR 01;38;5;220
LINK 01;04;38;5;229
MULTIHARDLINK 00
FIFO 01;38;5;220;40
SOCK 01;38;5;214
DOOR 01;38;5;214
BLK 01;38;5;230;48;5;94
CHR 01;38;5;230;48;5;94
ORPHAN 01;37;41
MISSING 00
SETUID 01;37;41
SETGID 01;30;43
CAPABILITY 01;37;41
STICKY_OTHER_WRITABLE 01;30;43
OTHER_WRITABLE 01;30;43
STICKY 01;30;48;5;229
EXEC 01;38;5;214

